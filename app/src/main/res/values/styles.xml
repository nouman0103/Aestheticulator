<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="button_main">
        <item name="android:background">@drawable/button_selector</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">17sp</item>
        <item name="android:shadowRadius">10</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:backgroundTintMode">multiply</item>
        <item name="android:backgroundTint">@color/neutral_top_button</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="button_calc_main" parent="button_main">
        <item name="android:backgroundTint">@color/neutral_bottom_button</item>
    </style>

    <style name="shifted_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_alignParentStart">true</item>
        <item name="android:outlineAmbientShadowColor">#00FFFFFF</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">#ebc113</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginStart">7dp</item>
    </style>

    <style name="shifted_text_middle" parent="shifted_text">
        <item name="android:layout_alignParentStart">false</item>
        <item name="android:layout_alignParentEnd">false</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_marginEnd">0dp</item>
        <item name="android:layout_centerInParent">true</item>
    </style>

    <style name="alpha_text" parent="shifted_text">
        <item name="android:layout_alignParentStart">false</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:textColor">#7165a8</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_marginEnd">7dp</item>
    </style>
    <style name="label_parent_layout">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

</resources>